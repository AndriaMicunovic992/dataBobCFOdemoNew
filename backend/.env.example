# Copy this file to .env and fill in your values.
# cp backend/.env.example backend/.env

# ── Database ──────────────────────────────────────────────────────────────────
# Matches the docker-compose.yml defaults — change only if you use an external PG.
DATABASE_URL=postgresql+asyncpg://databobiq:databobiq@localhost:5432/databobiq
DATABASE_URL_SYNC=postgresql://databobiq:databobiq@localhost:5432/databobiq

# ── Anthropic API keys ────────────────────────────────────────────────────────
# Two separate keys so you can use different Claude tiers per workload.
# CHAT  → conversational assistant, tool use, SSE streaming  (claude-sonnet)
# AGENT → one-shot schema analysis at upload time            (claude-haiku works fine)
ANTHROPIC_API_KEY_CHAT=sk-ant-...
ANTHROPIC_API_KEY_AGENT=sk-ant-...

# ── File storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
CORS_ORIGINS=http://localhost:5173
